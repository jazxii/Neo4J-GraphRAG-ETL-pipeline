# Neo4j Database Configuration
# Copy this file to .env and fill in your actual credentials

# ============================================================
# Neo4j Connection
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ============================================================
# WCAG Source Data
# ============================================================
# Use base JSON:     wcag_22_guidelines.json
# Use enriched JSON: wcag_22_guidelines_enriched.json
WCAG_JSON_FILE=wcag_22_guidelines.json

# ============================================================
# Agentic RAG — LLM Configuration
# ============================================================
# Provider: openai | ollama | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# For OpenAI / Anthropic:
OPENAI_API_KEY=sk-your-key-here

# For Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# OPENAI_API_KEY=ollama

# For Anthropic (via OpenAI-compatible endpoint):
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-4-20250514

# ============================================================
# Agentic RAG — Agent Configuration
# ============================================================
EMBEDDING_MODEL=text-embedding-3-small
MAX_AGENT_STEPS=10
MAX_CONTEXT_TOKENS=6000
LLM_TEMPERATURE=0.1
AGENT_VERBOSE=true
